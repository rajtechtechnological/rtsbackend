# Database Configuration
# Dev: leave DATABASE_URL empty and set LOCAL_DB_URL.
# Prod (Vercel): set DATABASE_URL to the Supabase TRANSACTION-mode pooler URL
# (Supavisor, port 6543) and SERVERLESS=true. See docs/07-DEPLOYMENT.md.
DATABASE_URL=
LOCAL_DB_URL=postgresql://username:password@localhost:5432/education_platform_dev
SERVERLESS=false

# Authentication
# REQUIRED — the app refuses to start without it. Use a long random string.
JWT_SECRET_KEY=your-secret-key-change-this-in-production-use-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
# Set false ONLY for local http dev (Secure cookies need https / localhost)
REFRESH_COOKIE_SECURE=true

# Application
FRONTEND_URL=http://localhost:3000

# File Storage
# Dev default: local disk under LOCAL_UPLOAD_DIR (served at /uploads).
# Prod: USE_LOCAL_STORAGE=false + Supabase Storage (public-read bucket).
USE_LOCAL_STORAGE=true
LOCAL_UPLOAD_DIR=./uploads

# Supabase Storage (prod only — leave empty for local development)
# SUPABASE_URL is the PROJECT API URL (https://<ref>.supabase.co), not the DB URL.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=rts-uploads

# "development" | "production" — production disables /docs and /openapi.json
# and restricts CORS to FRONTEND_URL only. Set to production on Vercel.
ENVIRONMENT=development
